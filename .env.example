# ============================================
# Instagram Otomatik Paylaşım Botu Yapılandırması
# ============================================
# Bu dosyayı kopyalayıp adını .env yapın ve bilgilerinizi doldurun
# Detaylı kurulum talimatları için SETUP_GUIDE.md dosyasına bakın

# Discord Yapılandırması
DISCORD_TOKEN=discord_token_buraya
CHANNEL_ID=1486099543849439487

# Instagram Hesapları (JSON dizisi)
# Tokenleri yenilemek için her 30 günde bir 'npm run instagram-refresh' komutunu çalıştırın
INSTAGRAM_ACCOUNTS=[{"name":"hesap1","id":"instagram_id","token":"instagram_token"}]

# GitHub Yapılandırması
GITHUB_TOKEN=github_token_buraya
GITHUB_OWNER=TheOrderx
GITHUB_REPO=insta-test

# YouTube OAuth Kimlik Bilgileri - İsteğe bağlı, sadece YouTube kullanılıyorsa gereklidir
# Bunları Google Cloud Console'dan alın (SETUP_GUIDE.md dosyasına bakın)
YOUTUBE_CLIENT_ID=client_id_buraya.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=client_secret_buraya
YOUTUBE_REDIRECT_URI=http://localhost:3000/oauth2callback

# YouTube Hesapları (JSON dizisi) - İsteğe bağlı, kullanmıyorsanız boş bırakın
# Tokenleri almak için 'npm run youtube-auth' komutunu çalıştırın (SETUP_GUIDE.md dosyasına bakın)
YOUTUBE_ACCOUNTS=[]

# Gemini AI API Anahtarı - Yapay zeka destekli açıklama oluşturmak için
# Ücretsiz API anahtarınızı buradan alın: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyBQ4Bkwvtb9gHxFBMJYwJuaZBbZad3Qej8

# Gemini Modeli (isteğe bağlı) - Varsayılan: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Video Markalaması (isteğe bağlı) - Varsayılan: true
# Videolardaki Netflix tarzı metin kaplamasını devre dışı bırakmak için false yapın
ADD_VIDEO_BRANDING=true

# ============================================
# Yararlı Komutlar
# ============================================
# Botu başlat:            npm start
# Instagram'ı yenile:     npm run instagram-refresh
# YouTube'u yenile:       npm run youtube-refresh
# YouTube yetkisi al:     npm run youtube-auth
# .env dosyasını test et: npm run test-env
ADD_VIDEO_BRANDING=true

# Instagram App ID ve Secret - Tokenleri otomatik yenilemek için
INSTAGRAM_APP_ID=uygulama_id_buraya
INSTAGRAM_APP_SECRET=uygulama_gizli_anahtari_buraya
